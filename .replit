entrypoint = "api_server.py"
modules = ["python-3.11", "nodejs-20"]

[nix]
channel = "stable-24_05"

[env]
PYTHONPATH = "."
NODE_ENV = "development"

[[ports]]
localPort = 8000
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 3000
externalPort = 3000
exposeLocalhost = true

[run]
args = ["bash", "start.sh"]

[deployment]
run = ["bash", "start.sh"]
deploymentTarget = "cloudrun"
