# =============================================================================
# Mobile Automation Pipeline — .gitignore
# =============================================================================

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
.cache

# Virtual environments
venv/
env/
ENV/
.venv/
.env/
pyvenv.cfg

# --- Environment & Secrets ---------------------------------------------------
.env
.env.local
.env.production
.env.*.local
dashboard/.env.local
dashboard/.env.production

# --- Node.js -----------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# --- Next.js -----------------------------------------------------------------
.next/
out/
dashboard/.next/
dashboard/out/

# --- Database ----------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
pipeline.db

# --- Artifacts & Media -------------------------------------------------------
artifacts/
!artifacts/.gitkeep
*.mp4
*.avi
*.mov
*.webm
*.apk
*.aab

# --- CV Templates (binary images) -------------------------------------------
# Keep the directory but not the actual template files in git
templates/*.png
templates/*.jpg
templates/*.jpeg
templates/*.bmp
!templates/.gitkeep

# --- Logs --------------------------------------------------------------------
logs/
*.log
*.log.*

# --- IDE & OS ----------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Replit ------------------------------------------------------------------
.upm/
.config/
.breakpoints

# --- Test outputs ------------------------------------------------------------
test-results/
playwright-report/
test-screenshots/

# --- Misc --------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.backup
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
