# =============================================================================
# Mobile Automation Pipeline — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# PROVIDER SELECTION
# Which device farm to use: "browserstack" | "aws_device_farm" | "local"
# -----------------------------------------------------------------------------
DEVICE_PROVIDER=local

# -----------------------------------------------------------------------------
# BROWSERSTACK — App Automate
# https://app-automate.browserstack.com/
# -----------------------------------------------------------------------------
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
BROWSERSTACK_APP_URL=                     # bs://... after uploading APK, optional
BROWSERSTACK_DEVICE=Google Pixel 7
BROWSERSTACK_OS_VERSION=13.0

# -----------------------------------------------------------------------------
# AWS DEVICE FARM
# https://console.aws.amazon.com/devicefarm/
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
AWS_DEVICE_FARM_PROJECT_ARN=              # arn:aws:devicefarm:us-west-2:...
AWS_DEVICE_FARM_DEVICE_POOL_ARN=          # arn:aws:devicefarm:us-west-2:...

# -----------------------------------------------------------------------------
# LOCAL DEVICE (ADB)
# For development and demo using a physical Android device or emulator
# -----------------------------------------------------------------------------
LOCAL_DEVICE_UDID=                        # e.g. emulator-5554 or your device serial
LOCAL_APPIUM_HOST=127.0.0.1
LOCAL_APPIUM_PORT=4723
ADB_PATH=/usr/local/bin/adb               # Path to ADB binary

# -----------------------------------------------------------------------------
# GOOGLE ACCOUNT CREDENTIALS
# Account to log in and use for Play Store / Google Pay
# WARNING: Use a dedicated test account — never your personal account
# -----------------------------------------------------------------------------
GOOGLE_ACCOUNT_EMAIL=
GOOGLE_ACCOUNT_PASSWORD=
GOOGLE_ACCOUNT_RECOVERY_EMAIL=            # Optional, for 2FA recovery

# -----------------------------------------------------------------------------
# GOOGLE PAY / PLAY BILLING
# For test purchases — account must be a licensed tester for the MLBB app
# https://developer.android.com/google/play/billing/test
# -----------------------------------------------------------------------------
GOOGLE_PAY_TEST_MODE=true                 # Use test card when true
GOOGLE_PLAY_TEST_CARD_NUMBER=             # Optional override for test card

# -----------------------------------------------------------------------------
# MLBB (Mobile Legends: Bang Bang)
# App identifiers
# -----------------------------------------------------------------------------
MLBB_PACKAGE_NAME=com.mobile.legends
MLBB_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.mobile.legends

# -----------------------------------------------------------------------------
# APPIUM CONFIGURATION
# -----------------------------------------------------------------------------
APPIUM_VERSION=2.0
APPIUM_SERVER_TIMEOUT=60                  # Seconds to wait for Appium server
APPIUM_IMPLICIT_WAIT=5                    # Implicit wait for element lookups
APPIUM_NEW_COMMAND_TIMEOUT=300            # Max idle time before session dies

# -----------------------------------------------------------------------------
# ORCHESTRATOR
# -----------------------------------------------------------------------------
TOTAL_TIME_BUDGET=180                     # Total run budget in seconds (3 minutes)
STEP_RETRY_COUNT=3                        # Number of retries per step
SCREENSHOT_ON_FAILURE=true                # Save screenshot on step failure
VIDEO_RECORDING=true                      # Record session video

# -----------------------------------------------------------------------------
# CV / OCR ENGINE
# -----------------------------------------------------------------------------
TESSERACT_CMD=/usr/bin/tesseract          # Path to tesseract binary
TEMPLATE_DIR=./templates                  # Directory with CV template images
CV_CONFIDENCE_THRESHOLD=0.8              # Minimum confidence for template match
OCR_LANGUAGE=eng                          # Tesseract language pack

# -----------------------------------------------------------------------------
# ARTIFACTS
# -----------------------------------------------------------------------------
ARTIFACTS_DIR=./artifacts                 # Where to store run artifacts
ARTIFACTS_RETENTION_DAYS=30              # Auto-cleanup after N days

# -----------------------------------------------------------------------------
# FASTAPI SERVER
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-random-secret-key-in-production
DATABASE_URL=sqlite:///./pipeline.db

# -----------------------------------------------------------------------------
# NEXT.JS DASHBOARD (dashboard/.env.local)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000  # FastAPI backend URL
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=         # Clerk publishable key
CLERK_SECRET_KEY=                          # Clerk secret key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
